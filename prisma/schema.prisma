generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model TrainingAccount {
  id             String    @id @default(cuid())
  xUsername      String    @unique
  xId            String
  displayName    String?
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  scopes         String
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model ReferenceAccount {
  id          String   @id @default(cuid())
  xUsername   String   @unique
  xId         String?
  displayName String?
  bio         String?
  reason      String?
  addedAt     DateTime @default(now())
}

model TrainingAction {
  id             String   @id @default(cuid())
  type           String
  targetUsername String?
  tweetId        String?
  executedAt     DateTime @default(now())
  status         String   @default("done")
}

model TimelinePost {
  id             String    @id @default(cuid())
  tweetId        String    @unique
  authorUsername String?
  content        String
  fetchedAt      DateTime  @default(now())
  score          Int?
  feedback       String?
  scoredAt       DateTime?
}

model TrainingStrategy {
  id         String   @id @default(cuid())
  content    String
  generation Int      @default(1)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model AccountFeedback {
  id         String   @id @default(cuid())
  xUsername  String
  displayName String?
  bio        String?
  score      Int      // 1-10
  reason     String?  // 1-5のとき：追加しない理由
  action     String   // "added" | "rejected"
  createdAt  DateTime @default(now())
}

model DiscoveryCandidate {
  id             String    @id @default(cuid())
  sourceUsername String    // 探索元参考アカウント
  xUsername      String
  xId            String
  displayName    String?
  bio            String?
  followersCount Int?
  followingCount Int?
  tweetCount     Int?
  aiScore        Int?      // Claude一次選別スコア 1-10
  aiReason       String?   // Claude選別理由
  userAction     String?   // "follow" | "skip" | null(未評価)
  executedAt     DateTime? // フォロー実行日時
  createdAt      DateTime  @default(now())
}

model DiscoveryState {
  id              String   @id @default(cuid())
  sourceUsername  String   @unique
  sourceUserId    String
  paginationToken String?  // 次ページトークン
  totalFetched    Int      @default(0)
  updatedAt       DateTime @updatedAt
}
